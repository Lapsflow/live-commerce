# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ONEWMS-FMS API
ONEWMS_PARTNER_KEY="your-partner-key"
ONEWMS_DOMAIN_KEY="your-domain-key"
ONEWMS_API_URL="https://api.onewms.co.kr/api.php"

# Vercel Cron Protection
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Email Notifications (TODO: Configure for production)
SENDGRID_API_KEY="your-sendgrid-api-key"
NOTIFICATION_FROM_EMAIL="noreply@example.com"
