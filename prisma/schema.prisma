// Prisma Schema for Live-Commerce
// 6 Core Models + RateLimit

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────── User Management ────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  role         Role     @default(SELLER)
  adminId      String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ✨ Seller Profile Fields
  channels String[] @default([]) // 활동 채널 (예: ["GRIP", "CLME", "YOUTUBE"])
  avgSales Int? // 평균 매출 (월간 평균)

  // Self-referential relation: Admin → Sellers
  admin   User?  @relation("AdminSellers", fields: [adminId], references: [id], onDelete: SetNull)
  sellers User[] @relation("AdminSellers")

  // Relations
  orders      Order[]     @relation
  adminOrders Order[]     @relation("AdminOrders")
  broadcasts  Broadcast[]
  sales       Sale[]
  proposals   Proposal[]
}

enum Role {
  MASTER
  SUB_MASTER
  ADMIN
  SELLER
}

// ──────────────────────── Product Management ────────────────────────

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  barcode     String   @unique
  sellPrice   Int
  supplyPrice Int
  totalStock  Int      @default(0)
  stockMujin  Int      @default(0)
  stock1      Int      @default(0)
  stock2      Int      @default(0)
  stock3      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ✨ ONEWMS Integration Fields
  onewmsCode    String? @unique // ONEWMS 상품코드
  onewmsBarcode String? // ONEWMS 바코드

  // Relations
  orderItems   OrderItem[]
  sales        Sale[]
  onewmsStocks OnewmsStockSync[]
}

// ──────────────────────── Order Management ────────────────────────

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  sellerId    String
  adminId     String?
  status      OrderStatus @default(PENDING)
  totalAmount Int         @default(0)
  memo        String?
  uploadedAt  DateTime    @default(now())
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // ✨ 수령자 정보 (Excel 업로드용)
  recipient String? // 수령자
  phone     String? // 연락처
  address   String? // 주소

  // ✨ 금액 정보
  totalMargin Int @default(0) // 총 마진

  // ✨ 입금/출고 상태 추적
  paymentStatus  PaymentStatus  @default(UNPAID)
  shippingStatus ShippingStatus @default(PENDING)

  // Relations
  seller             User                @relation(fields: [sellerId], references: [id])
  admin              User?               @relation("AdminOrders", fields: [adminId], references: [id])
  items              OrderItem[]
  onewmsMapping      OnewmsOrderMapping?
  onewmsDeliveryLogs OnewmsDeliveryLog[]

  // Indexes
  @@index([sellerId, uploadedAt])
  @@index([orderNo])
  @@index([paymentStatus, shippingStatus])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  UNPAID // 입금확인전
  PAID // 입금완료
}

enum ShippingStatus {
  PENDING // 대기
  PREPARING // 발송준비
  SHIPPED // 출고완료
  PARTIAL // 부분출고
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  createdAt DateTime @default(now())

  // ✨ Excel 업로드용 스냅샷 필드
  barcode     String // 바코드
  productName String // 상품명
  supplyPrice Int // 공급가 (개당)
  totalSupply Int // 공급가 합계 = supplyPrice × quantity
  margin      Int // 마진 = (입금액 / 수량) - supplyPrice

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  // Indexes
  @@index([orderId])
  @@index([productId])
}

// ──────────────────────── Broadcast Management ────────────────────────

model Broadcast {
  id          String            @id @default(cuid())
  code        String            @unique
  sellerId    String
  platform    BroadcastPlatform
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  status      BroadcastStatus   @default(SCHEDULED)
  memo        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  seller User   @relation(fields: [sellerId], references: [id])
  sales  Sale[]
}

enum BroadcastPlatform {
  GRIP
  CLME
  YOUTUBE
  TIKTOK
  BAND
  OTHER
}

enum BroadcastStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELED
}

// ──────────────────────── Sales Management ────────────────────────

model Sale {
  id          String   @id @default(cuid())
  saleNo      String   @unique
  sellerId    String
  productId   String
  broadcastId String?
  quantity    Int
  unitPrice   Int
  totalPrice  Int
  saleDate    DateTime @default(now())
  createdAt   DateTime @default(now())

  // Relations
  seller    User       @relation(fields: [sellerId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  broadcast Broadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)
}

// ──────────────────────── Proposal Management ────────────────────────

model Proposal {
  id          String         @id @default(cuid())
  companyName String
  contact     String
  phone       String
  productName String
  category    String
  description String
  status      ProposalStatus @default(PENDING)
  submittedBy String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [submittedBy], references: [id])

  @@index([status])
  @@index([submittedBy])
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ──────────────────────── ONEWMS Integration ────────────────────────

model OnewmsOrderMapping {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  onewmsOrderNo String  @unique // ONEWMS 주문번호
  transNo       String? // 송장번호

  status     String @default("pending") // pending, sent, shipped, failed
  csStatus   Int    @default(0) // ONEWMS CS상태
  holdStatus Int    @default(0) // ONEWMS 보류상태

  sentAt       DateTime? // ONEWMS 전송 시각
  lastSyncAt   DateTime? // 마지막 동기화 시각
  errorMessage String? // 에러 메시지
  retryCount   Int       @default(0) // 재시도 횟수

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([onewmsOrderNo])
  @@index([status])
  @@index([sentAt])
}

model OnewmsStockSync {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  productCode  String // ONEWMS 상품코드
  availableQty Int // ONEWMS 가용재고
  totalQty     Int // ONEWMS 총재고
  localQty     Int // 플랫폼 재고

  difference Int // 차이 (ONEWMS - Local)
  syncStatus String @default("synced") // synced, conflict, failed

  syncedAt DateTime @default(now())

  @@index([productId])
  @@index([syncedAt])
}

model OnewmsDeliveryLog {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  oldStatus String? // 이전 배송 상태
  newStatus String // 새로운 배송 상태
  transNo   String? // 송장번호

  changedAt  DateTime @default(now())
  syncedFrom String   @default("onewms") // onewms, manual, system

  @@index([orderId])
  @@index([changedAt])
}

// ──────────────────────── Rate Limiting ────────────────────────

model RateLimit {
  key         String   @id
  count       Int
  windowStart DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
